# i3 config file (v4)
#
# Please see https://i3wm.org/docs/userguide.html for a complete reference!

set $alt Mod1
set $mod Mod4
set $browser zen

font pango:JetBrainsMono Nerd Font Bold 14

# auto start ---------------------------

exec_always --no-startup-id picom
exec_always --no-startup-id ~/.config/polybar/launch_polybar.sh
exec --no-startup-id copyq --start-server
exec --no-startup-id dunst
exec --no-startup-id feh --bg-fill --randomize ~/Pictures/wallpapers/

# applications
exec --no-startup-id $browser
exec --no-startup-id wezterm start --class wezmain -e tmux new -A -s dev
exec --no-startup-id ticktick
exec --no-startup-id zapzap
exec --no-startup-id redshift-gtk

# scratch pads
exec --no-startup-id wezterm --config font_size=12 start --class btop -e btop
exec --no-startup-id wezterm start --class wezscratch -e tmux new -A -s scratch

# misc settings
exec --no-startup-id numlockx on # enable numlock on startup
exec --no-startup-id ~/.config/i3/scripts/toggle-touchpad.sh # disable touchpad on startup
exec --no-startup-id wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 0.3 # set default mic volume to 30%
exec --no-startup-id xset r rate 200 35 # keyboard repeat rate
exec --no-startup-id xset s off -dpms # disable auto-lock and screen dimming
exec --no-startup-id xss-lock --transfer-sleep-lock -- betterlockscreen --lock -- -e --nofork
# exec --no-startup-id /usr/lib/policykit-1-gnome/polkit-gnome-authentication-agent-1 # polkit agent for sudo password prompts

# key bindings -------------------------

# applications
bindsym $mod+Return exec wezterm -e tmux
bindsym $alt+space exec --no-startup-id ulauncher
bindsym $mod+e exec --no-startup-id nautilus &
bindsym $mod+c exec --no-startup-id gnome-calculator
bindsym $mod+w exec ~/.config/rofi/wallpaper/wallpaper.sh
bindsym $mod+x exec --no-startup-id ~/.config/rofi/powermenu/powermenu.sh
bindsym $mod+v exec --no-startup-id copyq toggle

# scratch pads
bindsym $mod+b [class="btop"] scratchpad show; move position center
bindsym $mod+o [class="wezscratch"] scratchpad show; move position center

# window management
bindsym $mod+q kill
bindsym $mod+f fullscreen toggle
bindsym $mod+t layout tabbed
bindsym $mod+s layout toggle split
bindsym $mod+$alt+h split v
bindsym $mod+$alt+v split h
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+a focus parent
bindsym $mod+Shift+a focus child

# touchpad toggle
bindsym XF86TouchpadToggle exec --no-startup-id ~/.config/i3/scripts/toggle-touchpad.sh

# media control
bindsym XF86AudioPlay exec --no-startup-id playerctl play-pause
bindsym XF86AudioNext exec --no-startup-id playerctl next
bindsym XF86AudioPrev exec --no-startup-id playerctl previous

# volume control
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/i3/scripts/volume.sh 5%+
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/i3/scripts/volume.sh 5%-
bindsym XF86AudioMute        exec --no-startup-id ~/.config/i3/scripts/volume.sh toggleMute
bindsym XF86AudioMicMute     exec --no-startup-id ~/.config/i3/scripts/toggle-mic.sh

# brightness control
bindsym XF86MonBrightnessUp         exec --no-startup-id ~/.config/i3/scripts/brightness.sh 2%+
bindsym XF86MonBrightnessDown       exec --no-startup-id ~/.config/i3/scripts/brightness.sh 2%-
bindsym Shift+XF86MonBrightnessUp   exec --no-startup-id ~/.config/i3/scripts/brightness.sh 50%
bindsym Shift+XF86MonBrightnessDown exec --no-startup-id ~/.config/i3/scripts/brightness.sh 0%

# screenshots
bindsym Print       exec flameshot full -c -p ~/Pictures/Screenshots/
bindsym Shift+Print exec flameshot gui  -c -p ~/Pictures/Screenshots/

# reload the configuration file
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart
bindsym $mod+p exec ~/.config/polybar/launch_polybar.sh

bindsym $mod+r mode "resize"
mode "resize" {
    bindsym h resize grow width 5 px or 5 ppt
    bindsym j resize shrink height 5 px or 5 ppt
    bindsym k resize grow height 5 px or 5 ppt
    bindsym l resize shrink width 5 px or 5 ppt

    # back to normal
    bindsym Escape mode "default"
    bindsym $mod+r mode "default"
}

# Mouse+$mod to drag floating windows
floating_modifier $mod
tiling_drag modifier titlebar

# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# window rules ------------------------

for_window [class="zen"] move to workspace $ws1
for_window [class="wezmain"] move to workspace $ws2
for_window [class="ticktick"] move to workspace $ws5
for_window [class="vesktop"] move to workspace $ws9
for_window [class="ZapZap"] move to workspace $ws10

# scratch pads
for_window [class="btop"] move scratchpad
for_window [class="btop"] resize set 1261 823

for_window [class="wezscratch"] move scratchpad
for_window [class="wezscratch"] resize set 1130 805

# floating windows
for_window [class="copyq"] floating enable
for_window [class="pavucontrol"] floating enable
for_window [class="wezfloat"] floating enable
for_window [class="gnome-calculator"] floating enable
for_window [class="Nautilus"] floating enable
for_window [class="Localsend"] floating enable

# appearance -----------------------

default_border none
default_floating_border none
focus_on_window_activation focus
hide_edge_borders smart
title_align center
workspace_layout tabbed

gaps inner 6
gaps outer 6

