[user]
	name = Bahaa Mohamed
	email = bahaa-dev@proton.me
	signingkey = 7427A4ABCCFD30AB
[core]
	pager = delta
	autocrlf = input
	excludesfile = $HOME/.gitignore_global
[commit]
	gpgsign = true
[credential "https://github.com"]
	helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = !/usr/bin/gh auth git-credential
[init]
	defaultbranch = main
[diff]
	algorithm = histogram
[delta]
    dark = true
    navigate = true
    hunk-header-style = syntax
